# Trading Analyst - Development Environment Template
#
# This file is auto-generated by ./scripts/dc.sh based on your directory name.
# You don't need to create or edit this manually.
#
# To regenerate with fresh values: delete .env.dev and run ./scripts/dc.sh
#
# To customize: edit the generated .env.dev file after it's created

# ============================================
# DOCKER COMPOSE PROJECT (Auto-generated)
# ============================================
# Format: {directory_name}_dev
COMPOSE_PROJECT_NAME=trading_analyst_dev

# ============================================
# PORT CONFIGURATION (Auto-derived from directory hash)
# ============================================
# Ports are deterministic based on directory name hash
# Range: postgres 5500-5599, backend 8100-8199, frontend 5200-5299
POSTGRES_PORT=5541
BACKEND_PORT=8141
FRONTEND_PORT=5241

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=trading_analyst_dev
POSTGRES_USER=trader
POSTGRES_PASSWORD=localpass
DATABASE_URL=postgresql+asyncpg://trader:localpass@postgres-dev:5432/trading_analyst_dev

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:5241,http://localhost:8141
